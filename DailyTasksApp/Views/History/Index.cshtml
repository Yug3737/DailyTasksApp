@model List<WeeklyTasks>
@{
    var successfulWeekThreshold = 0.5;
}

<div class="table-responsive">
    <table class="table table-dark table-hover table-striped ">
        <caption>List of past weeks' task completion data</caption>
        <tr>
            <thead class="thead-dark">
            <th class="fs-5">Start Date</th>
            <th class="fs-5">End Date</th>
            <th class="fs-5">Tasks Done</th>
            <th class="fs-5">Percent Completion</th>
            </thead>
        </tr>
        @foreach (var pastWeek in Model)
        {
            <tr>
                <td>
                    <a asp-controller="History" 
                       asp-action="PastWeek" 
                       asp-route-pastWeekId="@pastWeek.Id"
                       class="text-decoration-none">
                        @pastWeek.StartDate.ToString("MM-dd-yyyy")
                    </a>
                </td>
                <td>@pastWeek.EndDate.ToString("MM-dd-yyyy")</td>
                @{
                    var tasksDoneThisWeek = 0;
                    var totalTasksThisWeek = 0;
                    for (int i = 0; i < pastWeek.DailyTasksList.Count; i++)
                    {
                        tasksDoneThisWeek += pastWeek.DailyTasksList[i].TasksDone;
                        totalTasksThisWeek += pastWeek.DailyTasksList[i].TaskList.Count;
                    }
                }
                @{
                    var percentCompletion = (tasksDoneThisWeek / (float)totalTasksThisWeek * 100).ToString("#.##");
                }
                <td>@tasksDoneThisWeek/@totalTasksThisWeek</td>
                <td>@percentCompletion%</td>
            </tr>
        }
    </table>
</div>

