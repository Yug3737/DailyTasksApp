@model DailyTasks
@{
}

<div class="partial-container">
    <div class="gif-path">@Model.GifPath</div>
    <div class="d-flex align-items-center justify-content-between mb-3">
        <div class="day-of-week">
            <a class="text-light edit-single-tasks-link fs-3 text-decoration-none"
               style="cursor: pointer"
               data-daily-tasks-id="@Model.Id"
               >@Model.DayOfWeek</a>
        </div>
    </div>
    
    <div class="modal-overlay">
        <div class="edit-modal-body rounded p-4 shadow bg-dark">
            @*  partial gets injected here> *@
        </div>
    </div>
    
    <div class="daily-tasks-list">
        <form method="post" asp-action="SaveCheckedDailyTasks" asp-controller="DailyTasks">
            <input type="hidden" name="DailyTasksId" value="@Model.Id" />
            
            @foreach (var task in Model.TaskList)
            {
                <div class="single-task-row">
                    <input type="checkbox"
                           name="SingleTaskIds"
                           value="@task.Id"
                           class="text-light"
                           id="@task.Id"
                           @(task.IsDone ? "checked" : "") />
                    <label class="daily-task-title" for="@task.Id">@task.Title</label>
                </div>
            }
            
            <button type="submit" class="btn btn-success">Save done tasks</button>
        </form>
    </div>
    <div class="task-completion-msg">@Model.Message</div>
</div>